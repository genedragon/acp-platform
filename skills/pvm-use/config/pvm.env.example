# PVM Configuration
# Copy to pvm.env and fill in your values

# Required — Your PVM API Gateway endpoint
PVM_API_BASE="https://YOUR-API-ID.execute-api.YOUR-REGION.amazonaws.com/prod"

# Optional — Your IAM role ARN (auto-detected on EC2/Lambda if unset)
# PVM_REQUESTER_IDENTITY="arn:aws:iam::ACCOUNT:role/your-role"
