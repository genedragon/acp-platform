{
  "_comment": "Merge these sections into your ~/.openclaw/openclaw.json",

  "agents.list[] — add this entry": {
    "id": "webmaster",
    "name": "webmaster",
    "workspace": "~/.openclaw/workspace-webmaster",
    "model": {
      "primary": "amazon-bedrock/global.anthropic.claude-haiku-4-5-20251001-v1:0"
    }
  },

  "channels.zulip.accounts — add this entry": {
    "webmaster": {
      "botEmail": "webmaster-bot@YOUR-DOMAIN",
      "botToken": "YOUR-WEBMASTER-BOT-API-KEY",
      "dmPolicy": "open",
      "allowFrom": ["*"],
      "groupPolicy": "open"
    }
  },

  "bindings[] — add this entry": {
    "agentId": "webmaster",
    "match": {
      "channel": "zulip",
      "accountId": "webmaster"
    }
  }
}
